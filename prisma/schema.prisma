generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  provider   String
  providerId String    @map("provider_id")
  name       String
  email      String?
  picture    String?
  participations MarathonParticipation[]
  records        Activity[]
  userBadges     UserBadge[]
  notifications  Notification[]
  @@unique([provider, providerId])
  @@map("users")
}

model Marathon {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  name            String
  date            String
  location        String   @default("")
  city            String   @default("")
  categories      String   @default("")
  description     String   @default("")
  officialUrl     String   @default("") @map("official_url")
  entryFee        Int      @default(0) @map("entry_fee")
  maxParticipants Int      @default(0) @map("max_participants")
  isActive        Boolean  @default(true) @map("is_active")
  participations MarathonParticipation[]
  @@map("marathons")
}

model MarathonParticipation {
  id             Int       @id @default(autoincrement())
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  userId         Int       @map("user_id")
  marathonId     Int       @map("marathon_id")
  category       String    @default("")
  finishTime     Int?      @map("finish_time")
  raceNotes      String?   @map("race_notes")
  certificateUrl String?   @map("certificate_url")
  user    User    @relation(fields: [userId], references: [id])
  marathon Marathon @relation(fields: [marathonId], references: [id])
  @@unique([userId, marathonId])
  @@map("marathon_participations")
}

model Activity {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  userId      Int?      @map("user_id")
  date        String
  distance    Float
  duration    Int
  pace        String    @default("")
  paceSeconds Int       @default(0) @map("pace_seconds")
  heartRate   Int       @default(0) @map("heart_rate")
  calories    Int       @default(0)
  routeType   String    @default("road") @map("route_type")
  weather     String    @default("")
  notes       String    @default("")
  marathonId  Int?      @map("marathon_id")
  routeData   String    @default("") @map("route_data")
  user User? @relation(fields: [userId], references: [id])
  @@index([userId, distance])
  @@index([userId, duration])
  @@index([userId, paceSeconds])
  @@index([userId, date])
  @@map("activities")
}

model BadgeDefinition {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  type        String      // "monthly_km" | "streak" | "personal_best"
  name        String
  description String      @default("")
  icon        String      @default("")
  threshold   Int         @default(0)
  unit        String      @default("")
  userBadges  UserBadge[]
  @@map("badge_definitions")
}

model UserBadge {
  id          Int              @id @default(autoincrement())
  createdAt   DateTime         @default(now()) @map("created_at")
  userId      Int              @map("user_id")
  badgeId     Int              @map("badge_id")
  year        Int?
  month       Int?
  awardedAt   DateTime         @default(now()) @map("awarded_at")
  user        User             @relation(fields: [userId], references: [id])
  badge       BadgeDefinition  @relation(fields: [badgeId], references: [id])
  @@unique([userId, badgeId, year, month])
  @@index([userId])
  @@map("user_badges")
}

model Notification {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  userId    Int      @map("user_id")
  type      String   // "dday_7" | "dday_1" | "badge"
  refId     String   @map("ref_id")
  title     String
  body      String   @default("")
  isRead    Boolean  @default(false) @map("is_read")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, type, refId])
  @@index([userId, isRead])
  @@map("notifications")
}
