# ── DB ───────────────────────────────────────────────────────────────────────
# 로컬: 비워두면 SQLite(runmate.db) 자동 사용
# 배포: Supabase 프로젝트 Settings > Database > Connection String (URI) 복사
DATABASE_URL=

# ── 서버 ─────────────────────────────────────────────────────────────────────
PORT=8080

# 배포 URL (Render 배포 후 실제 주소로 변경)
# 로컬 개발 시 비워두면 http://localhost:8080 자동 사용
BASE_URL=

# 세션 암호화 키 (랜덤 문자열 32자 이상, Render에서는 자동 생성)
SESSION_SECRET=your-random-secret-key-change-this

# ── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
# 승인된 리디렉션 URI: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Kakao OAuth ───────────────────────────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → REST API 키
# Redirect URI: http://localhost:8080/auth/kakao/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Naver OAuth ───────────────────────────────────────────────────────────────
# https://developers.naver.com → Application 등록
# Callback URL: http://localhost:8080/auth/naver/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 선택 ─────────────────────────────────────────────────────────────────────
# 공공데이터포털 마라톤 API 키
# 발급: https://www.data.go.kr/data/15138980/fileData.do
MARATHON_API_KEY=
# Anthropic API 키 (크롤링 AI 파싱용)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=
